        "default_window": "hamming",
        "windows": [
          {
            "id": "barthann",
            "title": "Barthann"
          },
          {
            "id": "bartlett",
            "title": "Bartlett"
          },
          {
            "id": "blackman",
            "title": "Blackman"
          },
          {
            "id": "blackmanharris",
            "title": "Blackman-Harris"
          },
          {
            "id": "bohman",
            "title": "Bohman"
          },
          {
            "id": "boxcar",
            "title": "Boxcar"
          },
          {
            "id": "cosine",
            "title": "Cosine"
          },
          {
            "id": "exponential",
            "title": "Exponential"
          },
          {
            "id": "flattop",
            "title": "Flat top"
          },
          {
            "id": "hamming",
            "title": "Hamming"
          },
          {
            "id": "hann",
            "title": "Hann"
          },
          {
            "id": "lanczos",
            "title": "Lanczos"
          },
          {
            "id": "nuttall",
            "title": "Nuttall"
          },
          {
            "id": "parzen",
            "title": "Parzen"
          },
          {
            "id": "taylor",
            "title": "Taylor"
          },
          {
            "id": "triang",
            "title": "Triangular"
          }
        ]
      },
      "iir": {
        "default_design": "butter",
        "designs": [
          {
            "id": "butter",
            "title": "Butterworth"
          },
          {
            "id": "cheby1",
            "title": "Chebyshev I"
          },
          {
            "id": "cheby2",
            "title": "Chebyshev II"
          },
          {
            "id": "ellip",
            "title": "Elliptic"
          },
          {
            "id": "bessel",
            "title": "Bessel"
          }
        ],
        "default_order": 4,
        "default_rp_db": 1.0,
        "default_rs_db": 40.0
      }
    },
    "notch": {
      "enabled": true,
      "filter_type": "fir",
      "low_cut": 49.0,
      "high_cut": 51.0,
      "fir_order": 1001,
      "fir_window": "hamming",
      "iir_order": 4,
      "iir_design": "butter",
      "iir_rp_db": 1.0,
      "iir_rs_db": 40.0
    },
    "bandpass": {
      "enabled": true,
      "filter_type": "fir",
      "low_cut": 0.5,
      "high_cut": 60.0,
      "fir_order": 1000,
      "fir_window": "hamming",
      "iir_order": 4,
      "iir_design": "butter",
      "iir_rp_db": 1.0,
      "iir_rs_db": 40.0
    },
    "bands": {
      "available": [
        {
          "id": "delta",
          "title": "Delta",
          "low_cut": 0.5,
          "high_cut": 4.0,
          "enabled": true
        },
        {
          "id": "theta",
          "title": "Theta",
          "low_cut": 4.0,
          "high_cut": 8.0,
          "enabled": true
        },
        {
          "id": "alpha",
          "title": "Alpha",
          "low_cut": 8.0,
          "high_cut": 13.0,
          "enabled": true
        },
        {
          "id": "beta",
          "title": "Beta",
          "low_cut": 13.0,
          "high_cut": 30.0,
          "enabled": true
        },
        {
          "id": "gamma",
          "title": "Gamma",
          "low_cut": 30.0,
          "high_cut": 45.0,
          "enabled": true
        }
      ]
    }
  },
  "features": {
    "categories": [
      {
        "id": "spectral",
        "title": "Spectral features",
        "features": [
          {
            "id": "band_power",
            "title": "Band power",
            "subtitle": "Power inside each configured frequency band.",
            "checked_by_default": true
          },
          {
            "id": "relative_band_power",
            "title": "Relative band power",
            "subtitle": "Band power normalized by total power.",
            "checked_by_default": true
          }
        ]
      },
      {
        "id": "temporal",
        "title": "Temporal features",
        "features": [
          {
            "id": "mean_amplitude",
            "title": "Mean amplitude",
            "subtitle": "Average signal amplitude in the selected window.",
            "checked_by_default": true
          },
          {
            "id": "variance",
            "title": "Variance",
            "subtitle": "Second-order spread of the signal samples.",
            "checked_by_default": false
          }
        ]
      },
      {
        "id": "nonlinear",
        "title": "Non-linear features",
        "features": [
          {
            "id": "sample_entropy",
            "title": "Sample entropy",
            "subtitle": "Signal complexity estimation.",
            "checked_by_default": false
          }
        ]
      }
    ]
  },
  "report": {
    "include_metadata": true,
    "include_preprocessing_summary": true,
    "include_selected_features": true
  }
}
