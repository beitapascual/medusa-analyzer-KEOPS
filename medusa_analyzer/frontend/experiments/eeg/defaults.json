{
  "load_data": {
    "allowed_extensions": [
      ".edf", ".mat"
    ]
  },
  "preprocessing": {
    "car": {
      "enabled": true,
      "checked_by_default": true
    },
    "filters": [
      {
        "id": "notch",
        "title": "Notch filter",
        "mode": "bandstop",
        "plot_title": "Notch filter response",
        "must_be_within_filter": "bandpass",
        "out_of_range_warning": "Notch filter is outside the active bandpass range ({low:g}-{high:g} Hz) and will have no practical effect.",
        "enabled": true,
        "filter_type": "fir",
        "low_cut": 49.0,
        "high_cut": 51.0,
        "fir_order": 1001,
        "fir_window": "hamming",
        "iir_order": 4,
        "iir_design": "butter",
        "iir_rp_db": 1.0,
        "iir_rs_db": 40.0
      },
      {
        "id": "bandpass",
        "title": "Bandpass filter",
        "mode": "bandpass",
        "plot_title": "Bandpass filter response",
        "limits_frequency_bands": true,
        "enabled": true,
        "filter_type": "fir",
        "low_cut": 0.5,
        "high_cut": 60.0,
        "fir_order": 1000,
        "fir_window": "hamming",
        "iir_order": 4,
        "iir_design": "butter",
        "iir_rp_db": 1.0,
        "iir_rs_db": 40.0
      }
    ],
    "bands": {
      "available": [
        {
          "id": "delta",
          "title": "Delta",
          "low_cut": 0.5,
          "high_cut": 4.0,
          "enabled": true
        },
        {
          "id": "theta",
          "title": "Theta",
          "low_cut": 4.0,
          "high_cut": 8.0,
          "enabled": true
        },
        {
          "id": "alpha",
          "title": "Alpha",
          "low_cut": 8.0,
          "high_cut": 13.0,
          "enabled": true
        },
        {
          "id": "beta",
          "title": "Beta",
          "low_cut": 13.0,
          "high_cut": 30.0,
          "enabled": true
        },
        {
          "id": "gamma",
          "title": "Gamma",
          "low_cut": 30.0,
          "high_cut": 45.0,
          "enabled": true
        }
      ]
    }
  },
  "features": {
    "categories": [
      {
        "id": "spectral",
        "title": "Spectral features",
        "features": [
          {
            "id": "psd",
            "title": "PSD",
            "subtitle": "Power spectral density estimation.",
            "checked_by_default": true,
            "params": [
              {
                "id": "segment_percent",
                "title": "Segment (%)",
                "type": "int",
                "default": 80,
                "min": 1,
                "max": 100,
                "tooltip": "Percentage of the signal used per PSD segment."
              },
              {
                "id": "overlap_percent",
                "title": "Overlap (%)",
                "type": "int",
                "default": 50,
                "min": 0,
                "max": 100,
                "tooltip": "Percentage of overlap between consecutive PSD segments."
              },
              {
                "id": "window",
                "title": "Window",
                "type": "combo",
                "default": "hamming",
                "options": [
                  {
                    "id": "hamming",
                    "title": "Hamming"
                  },
                  {
                    "id": "bartlett",
                    "title": "Bartlett"
                  },
                  {
                    "id": "blackmanharris",
                    "title": "Blackman-Harris"
                  },
                  {
                    "id": "bohman",
                    "title": "Bohman"
                  },
                  {
                    "id": "boxcar",
                    "title": "Boxcar"
                  },
                  {
                    "id": "flattop",
                    "title": "Flat top"
                  },
                  {
                    "id": "nuttall",
                    "title": "Nuttall"
                  },
                  {
                    "id": "parzen",
                    "title": "Parzen"
                  },
                  {
                    "id": "triang",
                    "title": "Triangular"
                  }
                ],
                "tooltip": "Window function used for PSD estimation."
              }
            ]
          },
          {
            "id": "absolute_band_power",
            "title": "Absolute band power",
            "subtitle": "Absolute power computed in the frequency bands selected during preprocessing.",
            "checked_by_default": true,
            "params": [
              {
                "id": "selected_frequency_bands",
                "title": "bands",
                "type": "derived",
                "source": "feature_params.absolute_band_power.selected_frequency_bands",
                "format": "bands",
                "default": []
              }
            ]
          },
          {
            "id": "relative_band_power",
            "title": "Relative band power",
            "subtitle": "Band power normalized by total power across the selected preprocessing bands.",
            "checked_by_default": true,
            "params": [
              {
                "id": "selected_frequency_bands",
                "title": "bands",
                "type": "derived",
                "source": "feature_params.relative_band_power.selected_frequency_bands",
                "format": "bands",
                "default": []
              }
            ]
          },
          {
            "id": "median_frequency",
            "title": "Median frequency",
            "subtitle": "Frequency that divides the power spectrum into two regions with equal total power.",
            "checked_by_default": false
          },
          {
            "id": "spectral_entropy",
            "title": "Spectral Entropy",
            "subtitle": "Measure of how uniformly signal power is distributed across frequencies.",
            "checked_by_default": false
          }
        ]
      },
      {
        "id": "statistical",
        "title": "Basic statistical features",
        "features": [
          {
            "id": "mean",
            "title": "Mean",
            "subtitle": "Average value of the signal",
            "checked_by_default": true
          },
          {
            "id": "median",
            "title": "Median",
            "subtitle": "Median value of the signal.",
            "checked_by_default": true
          },
          {
            "id": "variance",
            "title": "Variance",
            "subtitle": "Second-order spread of the signal samples.",
            "checked_by_default": false
          },
          {
            "id": "kurtosis",
            "title": "Kurtosis",
            "subtitle": "Measure of the heaviness of the distribution tails.",
            "checked_by_default": false
          },
          {
            "id": "skewness",
            "title": "Skewness",
            "subtitle": "Measure of asymmetry of the signal distribution.",
            "checked_by_default": false
          }
        ]
      },
      {
        "id": "nonlinear",
        "title": "Non-linear features",
        "features": [
          {
            "id": "sample_entropy",
            "title": "Sample entropy",
            "subtitle": "Signal complexity estimation.",
            "checked_by_default": false,
            "params": [
              {
                "id": "m",
                "title": "m",
                "type": "int",
                "default": 1,
                "min": 1,
                "max": 10,
                "tooltip": "Embedding dimension used to compare signal patterns."
              },
              {
                "id": "r",
                "title": "r",
                "type": "float",
                "default": 0.1,
                "min": 0.0,
                "max": 10.0,
                "step": 0.01,
                "tooltip": "Tolerance threshold used to decide whether two patterns are similar."
              }
            ]
          },
          {
            "id": "ctm",
            "title": "Central tendency measure",
            "subtitle": "Quantifies how often points remain within a radius in the phase-space plot.",
            "checked_by_default": false,
            "params": [
              {
                "id": "r",
                "title": "r",
                "type": "float",
                "default": 0.075,
                "min": 0.0,
                "max": 10.0,
                "step": 0.001,
                "tooltip": "Radius used to count points around the origin in the second-order difference plot."
              }
            ]
          },
          {
            "id": "multiscale_sample_entropy",
            "title": "Multiscale sample entropy",
            "subtitle": "Sample entropy computed across multiple temporal scales.",
            "checked_by_default": false,
            "params": [
              {
                "id": "max_scale",
                "title": "Max scale",
                "type": "int",
                "default": 5,
                "min": 1,
                "max": 100,
                "tooltip": "Maximum temporal scale used for the multiscale analysis."
              },
              {
                "id": "m",
                "title": "m",
                "type": "int",
                "default": 1,
                "min": 1,
                "max": 10,
                "tooltip": "Embedding dimension used to compare signal patterns."
              },
              {
                "id": "r",
                "title": "r",
                "type": "float",
                "default": 0.1,
                "min": 0.0,
                "max": 10.0,
                "step": 0.01,
                "tooltip": "Tolerance threshold used to decide whether two patterns are similar."
              }
            ]
          },
          {
            "id": "lempel_ziv_complexity",
            "title": "Lempel-Ziv complexity",
            "subtitle": "Complexity metric based on the number of distinct symbolic patterns.",
            "checked_by_default": false
          },
          {
            "id": "multiscale_lempel_ziv_complexity",
            "title": "Multiscale Lempel-Ziv complexity",
            "subtitle": "Lempel-Ziv complexity computed across several temporal scales.",
            "checked_by_default": false,
            "params": [
              {
                "id": "scales",
                "title": "Scales",
                "type": "text",
                "default": "[1, 3, 5]",
                "tooltip": "List of temporal scales. Use Python-list format, for example [1, 3, 5]."
              }
            ]
          }
        ]
      },
      {
        "id": "connectivity",
        "title": "Connectivity features",
        "subcategories": [
          {
            "id": "amplitude",
            "title": "Amplitude connectivity",
            "features": [
              {
                "id": "aec",
                "title": "AEC",
                "subtitle": "Amplitude envelope correlation between pairs of signals.",
                "checked_by_default": false,
                "params": [
                  {
                    "id": "orthogonalize",
                    "title": "Orthogonalize",
                    "type": "checkbox",
                    "default": true,
                    "tooltip": "If enabled, signals are orthogonalized before computing amplitude envelope correlation to reduce zero-lag leakage effects."
                  }
                ]
              },
              {
                "id": "iac",
                "title": "IAC",
                "subtitle": "Instantaneous amplitude correlation between pairs of signals.",
                "checked_by_default": false,
                "params": [
                  {
                    "id": "orthogonalize",
                    "title": "Orthogonalize",
                    "type": "checkbox",
                    "default": true,
                    "tooltip": "If enabled, signals are orthogonalized before computing instantaneous amplitude correlation to reduce zero-lag leakage effects."
                  }
                ]
              }
            ]
          },
          {
            "id": "phase",
            "title": "Phase connectivity",
            "features": [
              {
                "id": "plv",
                "title": "PLV",
                "subtitle": "Phase locking value between pairs of signals.",
                "checked_by_default": false
              },
              {
                "id": "wpli",
                "title": "wPLI",
                "subtitle": "Weighted phase lag index between pairs of signals.",
                "checked_by_default": false
              },
              {
                "id": "pli",
                "title": "PLI",
                "subtitle": "Phase lag index between pairs of signals.",
                "checked_by_default": false
              }
            ]
          },
          {
            "id": "coherence",
            "title": "Coherence connectivity",
            "features": []
          }
        ]
      }
    ]
  },

  "report": {
    "include_metadata": true,
    "include_preprocessing_summary": true,
    "include_selected_features": true
  }
}
